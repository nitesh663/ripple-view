            "polyfills": ["zone.js", "zone.js/testing"],
            "karmaConfig": "projects/op-aggrid/karma.conf.js"
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": ["projects/op-aggrid/**/*.ts", "projects/op-aggrid/**/*.html"]
          }
        }
      }
    },
    "op-dynamic": {
      "projectType": "library",
      "root": "projects/op-dynamic",
      "sourceRoot": "projects/op-dynamic/src",
      "prefix": "op",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "project": "projects/op-dynamic/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/op-dynamic/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/op-dynamic/tsconfig.lib.json"
